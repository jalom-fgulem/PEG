# ──────────────────────────────────────────────────────────────────────────────
# SGPEG — variables de entorno de ejemplo
# Copiar a .env y rellenar con los valores reales
# ──────────────────────────────────────────────────────────────────────────────

# Aplicación
DEBUG=true
SECRET_KEY=cambia-esto-por-una-clave-segura-en-produccion

# Base de datos (SQL Server)
DB_SERVER=localhost
DB_NAME=SGPEG
DB_USER=sgpeg_user
DB_PASSWORD=tu_password
DB_DRIVER=ODBC Driver 17 for SQL Server

# SMTP — correo de notificaciones
# Para Office 365 / Exchange Online:
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=sgpeg@fgulem.es
SMTP_PASSWORD=tu_password_smtp
SMTP_FROM=sgpeg@fgulem.es

# Para Gmail (con contraseña de aplicación):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu_cuenta@gmail.com
# SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# SMTP_FROM=tu_cuenta@gmail.com
