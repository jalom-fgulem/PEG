IF OBJECT_ID('proveedor_servicio','U') IS NOT NULL DROP TABLE proveedor_servicio;\
IF OBJECT_ID('proveedor',        'U') IS NOT NULL DROP TABLE proveedor;\
IF OBJECT_ID('analitica',        'U') IS NOT NULL DROP TABLE analitica;\
IF OBJECT_ID('proyecto',         'U') IS NOT NULL DROP TABLE proyecto;\
IF OBJECT_ID('usuario',          'U') IS NOT NULL DROP TABLE usuario;\
IF OBJECT_ID('banco',            'U') IS NOT NULL DROP TABLE banco;\
IF OBJECT_ID('forma_pago',       'U') IS NOT NULL DROP TABLE forma_pago;\
IF OBJECT_ID('peg_estado',       'U') IS NOT NULL DROP TABLE peg_estado;\
IF OBJECT_ID('peg_tipo',         'U') IS NOT NULL DROP TABLE peg_tipo;\
