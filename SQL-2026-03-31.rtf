GO\
\
-- ============================================================\
-- TABLAS DE CAT\'c1LOGO / CONFIGURACI\'d3N\
-- ============================================================\
\
CREATE TABLE rol (\
    id_rol       INT IDENTITY(1,1) PRIMARY KEY,\
    codigo       NVARCHAR(50)  NOT NULL UNIQUE,\
    nombre       NVARCHAR(100) NOT NULL,\
    descripcion  NVARCHAR(255) NULL,\
    activo       BIT           NOT NULL DEFAULT 1\
);\
GO\
\
-- Datos iniciales de roles\
INSERT INTO rol (codigo, nombre, descripcion) VALUES\
    ('GESTOR_SERVICIO',  'Gestor de Servicio',  'Crea PEGs y proveedores de su propio servicio'),\
    ('GESTOR_ECONOMICO', 'Gestor Econ\'f3mico',    'Valida PEGs y gestiona remesas'),\
    ('ADMIN',            'Administrador',        'Gesti\'f3n de usuarios, servicios y configuraci\'f3n');\
GO\
\
-- ------------------------------------------------------------\
\
CREATE TABLE servicio (\
    id_servicio  INT IDENTITY(1,1) PRIMARY KEY,\
    codigo       NVARCHAR(50)  NOT NULL UNIQUE,\
    nombre       NVARCHAR(150) NOT NULL,\
    descripcion  NVARCHAR(255) NULL,\
    -- Cuentas contables A3Con (se configuran desde el panel de administraci\'f3n)\
    cuenta_gasto         NVARCHAR(20) NULL,\
    cuenta_iva_soportado NVARCHAR(20) NULL,\
    cuenta_tesoreria     NVARCHAR(20) NULL,\
    activo       BIT           NOT NULL DEFAULT 1\
);\
GO\
\
-- ------------------------------------------------------------\
\
CREATE TABLE proyecto (\
    id_proyecto  INT IDENTITY(1,1) PRIMARY KEY,\
    id_servicio  INT           NOT NULL,\
    codigo       NVARCHAR(50)  NOT NULL,\
    nombre       NVARCHAR(150) NOT NULL,\
    descripcion  NVARCHAR(255) NULL,\
    activo       BIT           NOT NULL DEFAULT 1,\
    CONSTRAINT UQ_proyecto_servicio_codigo UNIQUE (id_servicio, codigo),\
    CONSTRAINT FK_proyecto_servicio FOREIGN KEY (id_servicio) REFERENCES servicio(id_servicio)\
);\
GO\
\
-- ------------------------------------------------------------\
\
CREATE TABLE analitica (\
    id_analitica INT IDENTITY(1,1) PRIMARY KEY,\
    id_servicio  INT           NOT NULL,\
    id_proyecto  INT           NULL,\
    nivel_1      NVARCHAR(20)  NOT NULL,\
    nivel_2      NVARCHAR(20)  NULL,   -- NULL si el servicio no tiene nivel 2\
    descripcion  NVARCHAR(255) NOT NULL,\
    activo       BIT           NOT NULL DEFAULT 1,\
    CONSTRAINT FK_analitica_servicio FOREIGN KEY (id_servicio) REFERENCES servicio(id_servicio),\
    CONSTRAINT FK_analitica_proyecto FOREIGN KEY (id_proyecto) REFERENCES proyecto(id_proyecto)\
);\
GO\
\
-- ------------------------------------------------------------\
\
CREATE TABLE usuario (\
    id_usuario                  INT IDENTITY(1,1) PRIMARY KEY,\
    login                       NVARCHAR(100) NOT NULL UNIQUE,\
    nombre                      NVARCHAR(100) NOT NULL,\
    apellidos                   NVARCHAR(150) NOT NULL,\
    email                       NVARCHAR(150) NOT NULL,\
    password_hash               NVARCHAR(255) NOT NULL,\
    id_rol                      INT           NOT NULL,\
    -- NULL para ADMIN y GESTOR_ECONOMICO; obligatorio para GESTOR_SERVICIO\
    id_servicio                 INT           NULL,\
    activo                      BIT           NOT NULL DEFAULT 1,\
    recibe_notificaciones       BIT           NOT NULL DEFAULT 1,\
    recibe_notificaciones_peg   BIT           NOT NULL DEFAULT 1,\
    fecha_alta                  DATETIME2     NOT NULL DEFAULT SYSDATETIME(),\
    CONSTRAINT FK_usuario_rol      FOREIGN KEY (id_rol)      REFERENCES rol(id_rol),\
    CONSTRAINT FK_usuario_servicio FOREIGN KEY (id_servicio) REFERENCES servicio(id_servicio)\
);\
GO\
\
-- ------------------------------------------------------------\
\
CREATE TABLE forma_pago (\
    id_forma_pago INT IDENTITY(1,1) PRIMARY KEY,\
