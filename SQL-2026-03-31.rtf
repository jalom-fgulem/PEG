-- ============================================================\
-- PROVEEDORES\
-- ============================================================\
\
CREATE TABLE proveedor (\
    id_proveedor          INT IDENTITY(1,1) PRIMARY KEY,\
    tipo_persona          NVARCHAR(20)  NOT NULL,   -- FISICA / JURIDICA\
    cif_nif               NVARCHAR(20)  NOT NULL UNIQUE,\
    razon_social          NVARCHAR(200) NOT NULL,\
    nombre_comercial      NVARCHAR(200) NULL,\
    direccion             NVARCHAR(255) NULL,\
    codigo_postal         NVARCHAR(10)  NULL,\
    telefono              NVARCHAR(30)  NULL,\
    email                 NVARCHAR(150) NULL,\
    web                   NVARCHAR(150) NULL,\
    persona_contacto      NVARCHAR(150) NULL,\
    -- IBAN espa\'f1ol (ES + 22 d\'edgitos = 24 caracteres)\
    iban                  NVARCHAR(24)  NULL,\
    bic                   NVARCHAR(20)  NULL,\
    id_forma_pago_habitual INT          NULL,\
    retencion_aplicable   DECIMAL(5,2)  NULL,\
    tipo_iva_habitual     DECIMAL(5,2)  NULL,\
    observaciones         NVARCHAR(500) NULL,\
    activo                BIT           NOT NULL DEFAULT 1,\
    fecha_alta            DATETIME2     NOT NULL DEFAULT SYSDATETIME(),\
    CONSTRAINT FK_proveedor_forma_pago FOREIGN KEY (id_forma_pago_habitual)\
        REFERENCES forma_pago(id_forma_pago)\
);\
GO\
\
-- Relaci\'f3n muchos a muchos proveedor <-> servicio\
CREATE TABLE proveedor_servicio (\
    id_proveedor_servicio INT IDENTITY(1,1) PRIMARY KEY,\
    id_proveedor          INT  NOT NULL,\
    id_servicio           INT  NOT NULL,\
    habitual              BIT  NOT NULL DEFAULT 0,\
    activo                BIT  NOT NULL DEFAULT 1,\
    fecha_alta            DATETIME2 NOT NULL DEFAULT SYSDATETIME(),\
    CONSTRAINT UQ_proveedor_servicio          UNIQUE (id_proveedor, id_servicio),\
    CONSTRAINT FK_proveedor_servicio_prov     FOREIGN KEY (id_proveedor) REFERENCES proveedor(id_proveedor),\
    CONSTRAINT FK_proveedor_servicio_servicio FOREIGN KEY (id_servicio)  REFERENCES servicio(id_servicio)\
);\
GO\
\
-- ============================================================\
-- REMESAS\
-- ============================================================\
\
CREATE TABLE remesa (\
    id_remesa      INT IDENTITY(1,1) PRIMARY KEY,\
    codigo_remesa  NVARCHAR(50)  NOT NULL UNIQUE,\
    nombre         NVARCHAR(150) NOT NULL,\
    id_banco       INT           NOT NULL,\
    -- Estados: ABIERTA | ENVIADA | PAGADA\
    estado         NVARCHAR(20)  NOT NULL DEFAULT 'ABIERTA',\
    fecha_creacion DATETIME2     NOT NULL DEFAULT SYSDATETIME(),\
    fecha_envio    DATETIME2     NULL,\
    fecha_pago     DATETIME2     NULL,\
    creada_por     INT           NOT NULL,\
    -- Rutas a los archivos generados\
    archivo_cuaderno34  NVARCHAR(500) NULL,\
    archivo_a3con       NVARCHAR(500) NULL,\
    observaciones       NVARCHAR(1000) NULL,\
    CONSTRAINT FK_remesa_banco   FOREIGN KEY (id_banco)   REFERENCES banco(id_banco),\
    CONSTRAINT FK_remesa_usuario FOREIGN KEY (creada_por) REFERENCES usuario(id_usuario)\
);\
GO\
\
-- ============================================================\
-- PEGs\
-- ============================================================\
\
CREATE TABLE peg (\
    id_peg                INT IDENTITY(1,1) PRIMARY KEY,\
    codigo_peg            NVARCHAR(50)   NOT NULL UNIQUE,\
    id_servicio           INT            NOT NULL,\
    id_proyecto           INT            NULL,\
    id_proveedor          INT            NOT NULL,\
    id_peg_tipo           INT            NOT NULL,\
    numero_documento      NVARCHAR(100)  NOT NULL,\
    fecha_documento       DATE           NOT NULL,\
    fecha_recepcion       DATE           NOT NULL,\
    fecha_vencimiento     DATE           NULL,\
    -- Campo \'fanico de descripci\'f3n/concepto (no se repite por l\'ednea)\
    descripcion_gasto     NVARCHAR(500)  NOT NULL,\
    observaciones         NVARCHAR(1000) NULL,\
    id_forma_pago_prevista INT           NOT NULL,\
    -- Totales consolidados (suma de l\'edneas)\
    base_imponible_total  DECIMAL(18,2)  NOT NULL DEFAULT 0,\
    importe_iva_total     DECIMAL(18,2)  NOT NULL DEFAULT 0,\
    importe_irpf          DECIMAL(18,2)  NOT NULL DEFAULT 0,\
    importe_total         DECIMAL(18,2)  NOT NULL DEFAULT 0,\
    -- Estado y remesa\
    id_peg_estado         INT            NOT NULL,\
    id_remesa             INT            NULL,\
    id_analitica          INT            NULL,\
    -- Control de bloqueo e incidencias\
    bloqueado_pago        BIT            NOT NULL DEFAULT 0,\
    motivo_bloqueo        NVARCHAR(500)  NULL,\
    motivo_anulacion      NVARCHAR(500)  NULL,\
    -- Auditor\'eda\
    creado_por            INT            NOT NULL,\
    fecha_creacion        DATETIME2      NOT NULL DEFAULT SYSDATETIME(),\
    fecha_validacion      DATETIME2      NULL,\
    validado_por          INT            NULL,\
    fecha_pago            DATETIME2      NULL,\
    fecha_actualizacion   DATETIME2      NOT NULL DEFAULT SYSDATETIME(),\
    CONSTRAINT FK_peg_servicio    FOREIGN KEY (id_servicio)          REFERENCES servicio(id_servicio),\
    CONSTRAINT FK_peg_proyecto    FOREIGN KEY (id_proyecto)          REFERENCES proyecto(id_proyecto),\
    CONSTRAINT FK_peg_proveedor   FOREIGN KEY (id_proveedor)         REFERENCES proveedor(id_proveedor),\
    CONSTRAINT FK_peg_tipo        FOREIGN KEY (id_peg_tipo)          REFERENCES peg_tipo(id_peg_tipo),\
    CONSTRAINT FK_peg_forma_pago  FOREIGN KEY (id_forma_pago_prevista) REFERENCES forma_pago(id_forma_pago),\
    CONSTRAINT FK_peg_estado      FOREIGN KEY (id_peg_estado)        REFERENCES peg_estado(id_peg_estado),\
    CONSTRAINT FK_peg_remesa      FOREIGN KEY (id_remesa)            REFERENCES remesa(id_remesa),\
    CONSTRAINT FK_peg_analitica   FOREIGN KEY (id_analitica)         REFERENCES analitica(id_analitica),\
    CONSTRAINT FK_peg_creado_por  FOREIGN KEY (creado_por)           REFERENCES usuario(id_usuario),\
    CONSTRAINT FK_peg_validado_por FOREIGN KEY (validado_por)        REFERENCES usuario(id_usuario)\
);\
GO\
\
-- ------------------------------------------------------------\
-- L\'cdNEAS DE IVA DEL PEG (subformulario)\
-- ------------------------------------------------------------\
\
CREATE TABLE peg_linea (\
    id_peg_linea   INT IDENTITY(1,1) PRIMARY KEY,\
    id_peg         INT           NOT NULL,\
    orden          INT           NOT NULL DEFAULT 1,\
    -- Tipos de IVA oficiales: 0, 5, 10, 21\
    tipo_iva       DECIMAL(5,2)  NOT NULL,\
    base_imponible DECIMAL(18,2) NOT NULL,\
    -- Calculados y persistidos\
    importe_iva    AS (CAST(base_imponible * tipo_iva / 100 AS DECIMAL(18,2))) PERSISTED,\
    total_linea    AS (CAST(base_imponible + base_imponible * tipo_iva / 100 AS DECIMAL(18,2))) PERSISTED,\
    CONSTRAINT FK_peg_linea_peg FOREIGN KEY (id_peg) REFERENCES peg(id_peg)\
);\
GO\
\
-- ------------------------------------------------------------\
-- DOCUMENTOS ADJUNTOS AL PEG (m\'e1ximo 3-5 por PEG)\
-- ------------------------------------------------------------\
\
CREATE TABLE peg_documento (\
    id_peg_documento  INT IDENTITY(1,1) PRIMARY KEY,\
    id_peg            INT           NOT NULL,\
    id_tipo_documento INT           NOT NULL,\
    nombre_fichero    NVARCHAR(255) NOT NULL,\
    ruta_fichero      NVARCHAR(500) NOT NULL,\
    es_principal      BIT           NOT NULL DEFAULT 0,\
    activo            BIT           NOT NULL DEFAULT 1,\
    subido_por        INT           NOT NULL,\
    fecha_subida      DATETIME2     NOT NULL DEFAULT SYSDATETIME(),\
    CONSTRAINT FK_peg_documento_peg     FOREIGN KEY (id_peg)            REFERENCES peg(id_peg),\
    CONSTRAINT FK_peg_documento_tipo    FOREIGN KEY (id_tipo_documento)  REFERENCES tipo_documento(id_tipo_documento),\
    CONSTRAINT FK_peg_documento_usuario FOREIGN KEY (subido_por)         REFERENCES usuario(id_usuario)\
);\
GO\
\
-- ------------------------------------------------------------\
-- HISTORIAL DE CAMBIOS DE ESTADO\
-- ------------------------------------------------------------\
\
CREATE TABLE peg_historial (\
    id_peg_historial      INT IDENTITY(1,1) PRIMARY KEY,\
    id_peg                INT            NOT NULL,\
    id_peg_estado_origen  INT            NULL,\
    id_peg_estado_destino INT            NOT NULL,\
    comentario            NVARCHAR(1000) NULL,\
    realizado_por         INT            NOT NULL,\
    fecha_cambio          DATETIME2      NOT NULL DEFAULT SYSDATETIME(),\
    CONSTRAINT FK_peg_historial_peg     FOREIGN KEY (id_peg)                 REFERENCES peg(id_peg),\
    CONSTRAINT FK_peg_historial_origen  FOREIGN KEY (id_peg_estado_origen)   REFERENCES peg_estado(id_peg_estado),\
    CONSTRAINT FK_peg_historial_destino FOREIGN KEY (id_peg_estado_destino)  REFERENCES peg_estado(id_peg_estado),\
    CONSTRAINT FK_peg_historial_usuario FOREIGN KEY (realizado_por)          REFERENCES usuario(id_usuario)\
);\
GO\
\
-- ------------------------------------------------------------\
-- INCIDENCIAS\
-- ------------------------------------------------------------\
\
CREATE TABLE peg_incidencia (\
    id_peg_incidencia INT IDENTITY(1,1) PRIMARY KEY,\
