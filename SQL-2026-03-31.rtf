    CONSTRAINT FK_peg_incidencia_peg     FOREIGN KEY (id_peg)       REFERENCES peg(id_peg),\
    CONSTRAINT FK_peg_incidencia_creada  FOREIGN KEY (creada_por)   REFERENCES usuario(id_usuario),\
    CONSTRAINT FK_peg_incidencia_cerrada FOREIGN KEY (cerrada_por)  REFERENCES usuario(id_usuario)\
);\
GO\
